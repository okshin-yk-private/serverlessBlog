{
  "name": "@serverless-blog/deploy",
  "version": "1.0.0",
  "type": "module",
  "description": "Atomic deployment scripts for Serverless Blog",
  "private": true,
  "scripts": {
    "deploy": "tsx cli.ts",
    "deploy:dry-run": "tsx cli.ts --dry-run",
    "astro-deploy": "tsx astroLocalDeployCli.ts",
    "astro-deploy:dry-run": "tsx astroLocalDeployCli.ts --dry-run",
    "test": "vitest",
    "test:coverage": "vitest --coverage"
  },
  "dependencies": {
    "@aws-sdk/client-cloudfront": "^3.700.0",
    "@aws-sdk/client-s3": "^3.700.0",
    "commander": "^13.1.0",
    "mime-types": "^2.1.35"
  },
  "overrides": {
    "fast-xml-parser": "^5.5.7"
  },
  "devDependencies": {
    "@types/mime-types": "^2.1.4",
    "@types/node": "^22.12.0",
    "@vitest/coverage-v8": "^4.0.17",
    "tsx": "^4.19.3",
    "typescript": "^5.7.0",
    "vitest": "^4.0.17"
  }
}
