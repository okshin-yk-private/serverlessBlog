#!/bin/sh
# Pre-commit hook: Lint first (fast), then run tests for changed components
# Skip all checks with: git commit --no-verify

# Step 1: Run lint-staged for quick formatting/linting (existing behavior)
echo "=== Running lint-staged (format + lint) ==="
npx lint-staged || exit 1

# Step 2: Run component-specific tests based on staged files
echo ""
echo "=== Running pre-commit tests ==="
.husky/scripts/pre-commit-tests.sh
