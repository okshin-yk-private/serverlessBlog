// Claude Code + Codex Review Daemon Layout
// Usage: zellij --layout .zellij/layouts/claude-codex.kdl

layout {
    default_tab_template {
        pane size=1 borderless=true {
            plugin location="compact-bar"
        }
        children
    }

    tab name="AI Dev" focus=true {
        pane split_direction="vertical" {
            // Left pane: Claude Code (60% width)
            // Wrapper provides restart menu when Claude exits
            pane size="60%" name="Claude Code" {
                command "bash"
                args "-c" "./scripts/run-claude.sh"
            }
            // Right pane: Codex Review Daemon (40% width)
            // Wrapper provides restart menu when daemon exits
            pane size="40%" name="Codex Daemon" {
                command "bash"
                args "-c" "./scripts/run-codex-daemon.sh"
            }
        }
    }

    tab name="Shell" {
        pane name="Terminal"
    }
}
