{
  "name": "serverless-blog",
  "version": "1.0.0",
  "type": "module",
  "description": "AWS Serverless Blog System",
  "license": "MIT",
  "scripts": {
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:integration:frontend:public": "jest --config=jest.integration.frontend.config.cjs --testPathPattern=tests/integration/frontend/public",
    "test:integration:frontend:admin": "jest --config=jest.integration.frontend.config.cjs --testPathPattern=tests/integration/frontend/admin",
    "test:integration:frontend:auth": "jest --config=jest.integration.frontend.config.cjs --testPathPattern=tests/integration/frontend/auth",
    "test:integration:frontend:all": "jest --config=jest.integration.frontend.config.cjs --testPathPattern=tests/integration/frontend",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "HEADLESS=false playwright test",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:report": "playwright show-report",
    "test:e2e:admin": "playwright test --config=playwright.admin.config.ts",
    "test:e2e:admin:ui": "playwright test --config=playwright.admin.config.ts --ui",
    "test:e2e:admin:headed": "HEADLESS=false playwright test --config=playwright.admin.config.ts",
    "test:e2e:admin:debug": "playwright test --config=playwright.admin.config.ts --debug",
    "test:e2e:admin:report": "playwright show-report playwright-report-admin",
    "test:e2e:all": "bun run test:e2e && bun run test:e2e:admin",
    "test:e2e:aws": "VITE_ENABLE_MSW_MOCK=false playwright test --config=playwright.aws.config.ts --project=chromium",
    "test:e2e:aws:public": "VITE_ENABLE_MSW_MOCK=false playwright test --config=playwright.aws.config.ts --project=chromium tests/e2e/specs/home.spec.ts tests/e2e/specs/article.spec.ts",
    "test:e2e:aws:admin": "VITE_ENABLE_MSW_MOCK=false playwright test --config=playwright.aws.config.ts --project=chromium tests/e2e/specs/admin-auth.spec.ts tests/e2e/specs/admin-crud.spec.ts tests/e2e/specs/admin-unauthorized-access.spec.ts",
    "cleanup:test-data": "node scripts/cleanup-test-data.js",
    "coverage:badges": "node scripts/generate-coverage-badges.js",
    "coverage:report": "bun run test:coverage && bun run coverage:badges",
    "lint": "eslint . --ext .ts,.tsx",
    "lint:fix": "eslint . --ext .ts,.tsx --fix",
    "lint:frontend": "cd frontend/admin && eslint . --ext .ts,.tsx",
    "lint:functions": "eslint functions --ext .ts",
    "lint:infra": "cd infrastructure && eslint . --ext .ts",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "prepare": "husky"
  },
  "dependencies": {
    "@aws-lambda-powertools/logger": "^2.0.0",
    "@aws-lambda-powertools/metrics": "^2.0.0",
    "@aws-lambda-powertools/tracer": "^2.0.0",
    "@aws-sdk/client-dynamodb": "^3.490.0",
    "@aws-sdk/client-s3": "^3.490.0",
    "@aws-sdk/lib-dynamodb": "^3.490.0",
    "@aws-sdk/s3-request-presigner": "^3.490.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.56.1",
    "@types/aws-lambda": "^8.10.157",
    "@types/jest": "^29.5.11",
    "@types/node": "^20.10.6",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-import": "^2.29.1",
    "eslint-plugin-prettier": "^5.2.1",
    "husky": "^9.0.11",
    "jest": "^29.7.0",
    "lint-staged": "^15.2.0",
    "msw": "^2.0.0",
    "prettier": "^3.3.3",
    "ts-jest": "^29.1.1",
    "typescript": "^5.3.3",
    "uuid": "^13.0.0"
  }
}
