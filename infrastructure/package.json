{
  "name": "serverless-blog-infrastructure",
  "version": "1.0.0",
  "description": "Infrastructure as Code for Serverless Blog",
  "scripts": {
    "build": "tsc",
    "watch": "tsc -w",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "cdk": "cdk",
    "cdk:synth": "cdk synth --all",
    "cdk:nag": "cdk synth --all --quiet 2>&1 | grep -E '(AwsSolutions|Error|Warning)'",
    "lint": "eslint . --ext .ts",
    "lint:fix": "eslint . --ext .ts --fix"
  },
  "devDependencies": {
    "@types/jest": "^29.5.11",
    "@types/node": "^20.10.6",
    "aws-cdk": "^2.219.0",
    "esbuild": "^0.27.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  },
  "dependencies": {
    "aws-cdk-lib": "^2.219.0",
    "cdk-nag": "^2.28.0",
    "constructs": "^10.3.0"
  }
}
