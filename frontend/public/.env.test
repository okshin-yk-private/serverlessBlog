# E2E Test Environment Variables
# This file is loaded when running `npm run dev:e2e` (vite --mode test)

# Enable MSW (Mock Service Worker) for E2E tests
VITE_ENABLE_MSW_MOCK=true

# VITE_API_BASE_URL is intentionally NOT set here.
# When undefined, both api.ts (|| '/api') and handlers.ts (!== undefined -> '/api')
# default to '/api', ensuring MSW intercepts match app requests.
