---
/**
 * Layout.astro - 共通レイアウトコンポーネント
 *
 * Requirements:
 * - 14.1, 14.2: 日本語対応 (<html lang="ja">)
 * - 1.6: 静的HTML生成の基盤
 * - 3.1-3.7: SEOメタタグ対応
 * - 4.1-4.4: JSON-LD構造化データ対応
 */

import SEO from '../components/SEO.astro';
import JsonLd from '../components/JsonLd.astro';
import type { JsonLdPost } from '../lib/jsonLdUtils';

interface Props {
  /** Page title */
  title: string;
  /** Meta description (defaults to site description) */
  description?: string;
  /** Canonical URL for the page */
  canonicalUrl?: string;
  /** Open Graph type (website or article) */
  type?: 'website' | 'article';
  /** OG/Twitter image URL */
  imageUrl?: string;
  /** Article published date (ISO 8601) */
  publishedAt?: string;
  /** Article modified date (ISO 8601) */
  modifiedAt?: string;
  /** Whether to add noindex directive */
  noindex?: boolean;
  /** JSON-LD post data (for article pages) */
  jsonLdPost?: JsonLdPost;
  /** Show WebSite JSON-LD (for home page) */
  showWebSiteJsonLd?: boolean;
}

const SITE_NAME = 'bone of my fallacy';
const DEFAULT_DESCRIPTION = 'プログラミング、テクノロジー、ライフスタイルについてのブログ';

const {
  title,
  description = DEFAULT_DESCRIPTION,
  canonicalUrl = Astro.url.href,
  type = 'website',
  imageUrl,
  publishedAt,
  modifiedAt,
  noindex = false,
  jsonLdPost,
  showWebSiteJsonLd = false,
} = Astro.props;
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <!-- Favicon -->
    <link rel="icon" type="image/png" href="/favicon.png" />

    <!-- Preload Caveat font (self-hosted to eliminate FOUT) -->
    <link rel="preload" href="/fonts/caveat-variable.woff2" as="font" type="font/woff2" crossorigin />

    <!-- Shippori Mincho only (Caveat is self-hosted) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Shippori+Mincho:wght@400;600&display=swap" rel="stylesheet" />

    <!-- SEO Meta Tags (Task 3.1) -->
    <SEO
      title={title}
      description={description}
      canonicalUrl={canonicalUrl}
      type={type}
      imageUrl={imageUrl}
      publishedAt={publishedAt}
      modifiedAt={modifiedAt}
      noindex={noindex}
      siteName={SITE_NAME}
    />

    <!-- JSON-LD Structured Data (Task 3.2) -->
    {jsonLdPost && (
      <JsonLd type="BlogPosting" post={jsonLdPost} />
    )}
    {showWebSiteJsonLd && (
      <JsonLd type="WebSite" siteName={SITE_NAME} siteDescription={description} />
    )}

    <!-- Global Styles -->
    <style>
      @import '../styles/global.css';
    </style>
  </head>
  <body class="min-h-screen bg-gray-50">
    <slot />
  </body>
</html>
