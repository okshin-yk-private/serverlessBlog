---
/**
 * [id].astro - 記事詳細ページ
 *
 * Task 2.3: 記事詳細ページ実装
 * Task 3.1: SEOメタタグ実装
 * Task 3.2: JSON-LD構造化データ実装
 * Task 11.2: 記事埋め込みマインドマップの描画実装
 *
 * Requirements:
 * - 2.3: 記事詳細ページ実装
 *   - 動的ルート (`posts/[id].astro`) で各記事の詳細ページを生成
 *   - `getStaticPaths` で全公開記事のパスを生成
 *   - 記事タイトル、本文HTML、カテゴリ、タグ、画像を表示
 *   - サニタイズ済みHTMLコンテンツを `set:html` で安全にレンダリング
 *   - ビルド時に `/posts/[id]/index.html` として静的生成
 * - 2.7: CSS/アセットをインライン化またはバンドル
 * - 3.4: Article pages set og:type to "article"
 * - 3.5: Post's first image as og:image if available
 * - 4.1: JSON-LD structured data with @type: "BlogPosting" schema
 * - 4.2: Include headline, datePublished, dateModified, and author properties
 * - 4.3: If the post has images, include image property
 * - 5.3: 埋め込みマーカーをインタラクティブなマインドマップビューに置換
 * - 5.4: Astro SSGビルド時に埋め込み対象のマインドマップデータをJSON形式で埋め込む
 * - 5.5: 埋め込み対象が削除/非公開の場合フォールバックメッセージを表示
 */
import Layout from '../../layouts/Layout.astro';
import { fetchAllPosts, fetchPublicMindmap, type Post, type PublicMindmap } from '../../lib/api';
import {
  generateDescription,
  formatPublishedDate,
  getFirstImage,
  getPostImageUrls,
} from '../../lib/postDetailUtils';
import type { JsonLdPost } from '../../lib/jsonLdUtils';

/**
 * Extract mindmap IDs from HTML content containing embed divs.
 * Matches: data-mindmap-id="UUID" or data-mindmap-id='UUID'
 * Supports optional whitespace around '=' and both quote styles.
 */
function extractMindmapIds(html: string): string[] {
  if (!html) return [];
  const pattern = /data-mindmap-id\s*=\s*(?:"([^"]+)"|'([^']+)')/g;
  const ids: string[] = [];
  let match: RegExpExecArray | null;
  while ((match = pattern.exec(html)) !== null) {
    // match[1] is double-quoted value, match[2] is single-quoted value
    const id = match[1] || match[2];
    if (id && !ids.includes(id)) {
      ids.push(id);
    }
  }
  return ids;
}

/**
 * getStaticPaths: 全公開記事のパスを生成
 */
export async function getStaticPaths() {
  const posts = await fetchAllPosts();

  return posts.map((post) => ({
    params: { id: post.id },
    props: { post },
  }));
}

interface Props {
  post: Post;
}

const { post } = Astro.props;
const description = generateDescription(post.contentHtml);
const publishedDate = formatPublishedDate(post);
const firstImage = getFirstImage(post.imageUrls);
const images = getPostImageUrls(post);

// SEO: publishedAt or createdAt for article meta
const articlePublishedAt = post.publishedAt ?? post.createdAt;
const articleModifiedAt = post.updatedAt;

// JSON-LD: BlogPosting structured data (Task 3.2)
const jsonLdPost: JsonLdPost = {
  id: post.id,
  title: post.title,
  description: description,
  publishedAt: articlePublishedAt,
  updatedAt: articleModifiedAt,
  authorName: post.authorId || 'Anonymous',
  imageUrl: firstImage,
};

// Task 11.2: Fetch embedded mindmap data at build time (Req 5.4)
const embeddedMindmapIds = extractMindmapIds(post.contentHtml);
const embeddedMindmaps: Map<string, PublicMindmap> = new Map();

// Fetch all embedded mindmaps in parallel to reduce SSG build time
await Promise.all(
  embeddedMindmapIds.map(async (mmId) => {
    try {
      const mindmap = await fetchPublicMindmap(mmId);
      embeddedMindmaps.set(mmId, mindmap);
    } catch {
      // Mindmap not found or unpublished — will show fallback (Req 5.5)
    }
  })
);

const hasEmbeddedMindmaps = embeddedMindmapIds.length > 0;
---

<Layout
  title={post.title}
  description={description}
  type="article"
  imageUrl={firstImage}
  publishedAt={articlePublishedAt}
  modifiedAt={articleModifiedAt}
  jsonLdPost={jsonLdPost}
>
  <article class="post-detail">
    <header class="post-header">
      <div class="post-meta">
        <span class="category" data-testid="post-category">{post.category}</span>
        <time class="date" datetime={post.publishedAt ?? post.createdAt} data-testid="post-date">
          {publishedDate}
        </time>
      </div>
      <h1 class="post-title" data-testid="article-title">{post.title}</h1>
      {post.tags && post.tags.length > 0 && (
        <div class="tags" data-testid="post-tags">
          {post.tags.map((tag) => (
            <span class="tag">{tag}</span>
          ))}
        </div>
      )}
    </header>

    {/* Hero Image (if available) */}
    {firstImage && (
      <div class="hero-image">
        <img src={firstImage} alt={post.title} loading="eager" />
      </div>
    )}

    {/* Article Content - Sanitized HTML */}
    <div class="post-content" data-testid="article-content" set:html={post.contentHtml} />

    {/* Task 11.2: Embedded mindmap data as JSON (Req 5.4) */}
    {Array.from(embeddedMindmaps.entries()).map(([mmId, mindmap]) => (
      <script
        is:inline
        type="application/json"
        data-embed-mindmap-id={mmId}
        set:html={mindmap.nodes.replace(/</g, '\\u003c')}
      />
    ))}

    {/* Task 11.2: Mindmap embed viewer script (Req 5.3) */}
    {hasEmbeddedMindmaps && (
      <script>
        import { initMindmapEmbeds } from '../../scripts/mindmap-embed-viewer';
        document.addEventListener('DOMContentLoaded', initMindmapEmbeds);
      </script>
    )}

    {/* Article Images Gallery (if multiple images) */}
    {images.length > 1 && (
      <div class="image-gallery">
        {images.slice(1).map((imageUrl, index) => (
          <img src={imageUrl} alt={`${post.title} - Image ${index + 2}`} loading="lazy" />
        ))}
      </div>
    )}

    {/* Back to Home Link */}
    <nav class="post-navigation">
      <a href="/" class="back-link">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M19 12H5"></path>
          <path d="M12 19l-7-7 7-7"></path>
        </svg>
        Back
      </a>
    </nav>
  </article>
</Layout>

<style>
  .post-detail {
    max-width: 800px;
    margin: 0 auto;
    padding: 60px 32px;
  }

  .post-header {
    margin-bottom: 32px;
  }

  .post-meta {
    display: flex;
    gap: 16px;
    align-items: center;
    margin-bottom: 16px;
  }

  .category {
    background: #2D2A5A;
    padding: 6px 16px;
    border-radius: 6px;
    color: white;
    font-weight: 500;
    font-size: 0.875rem;
  }

  .date {
    color: #6b7280;
    font-size: 0.875rem;
  }

  .post-title {
    font-size: 2.5rem;
    font-weight: 700;
    color: #111827;
    line-height: 1.3;
    margin: 0 0 16px 0;
    font-family: 'Caveat', cursive;
  }

  .tags {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
  }

  .tag {
    background: #f3f4f6;
    padding: 4px 12px;
    border-radius: 4px;
    font-size: 0.8rem;
    color: #4b5563;
    font-weight: 500;
    border: 1px solid #e5e7eb;
  }

  .hero-image {
    margin-bottom: 32px;
    border-radius: 12px;
    overflow: hidden;
  }

  .hero-image img {
    width: 100%;
    height: auto;
    display: block;
  }

  .post-content {
    font-size: 1.125rem;
    line-height: 1.8;
    color: #374151;
  }

  /* Content HTML Styles */
  .post-content :global(h1),
  .post-content :global(h2),
  .post-content :global(h3),
  .post-content :global(h4),
  .post-content :global(h5),
  .post-content :global(h6) {
    color: #111827;
    margin-top: 2rem;
    margin-bottom: 1rem;
    font-weight: 600;
    line-height: 1.4;
  }

  .post-content :global(h2) {
    font-size: 1.75rem;
  }

  .post-content :global(h3) {
    font-size: 1.5rem;
  }

  .post-content :global(p) {
    margin-bottom: 1.5rem;
  }

  .post-content :global(a) {
    color: #C9A857;
    text-decoration: underline;
    transition: color 0.2s ease;
  }

  .post-content :global(a:hover) {
    color: #2D2A5A;
  }

  .post-content :global(ul),
  .post-content :global(ol) {
    margin-bottom: 1.5rem;
    padding-left: 2rem;
  }

  .post-content :global(li) {
    margin-bottom: 0.5rem;
  }

  .post-content :global(blockquote) {
    border-left: 4px solid #C9A857;
    padding-left: 1.5rem;
    margin: 1.5rem 0;
    color: #6b7280;
    font-style: italic;
  }

  .post-content :global(code) {
    background: #f3f4f6;
    padding: 0.2rem 0.4rem;
    border-radius: 4px;
    font-size: 0.9em;
    font-family: 'Fira Code', 'Consolas', monospace;
  }

  .post-content :global(pre) {
    background: #1f2937;
    color: #e5e7eb;
    padding: 1rem 1.5rem;
    border-radius: 8px;
    overflow-x: auto;
    margin: 1.5rem 0;
  }

  .post-content :global(pre code) {
    background: transparent;
    padding: 0;
    font-size: 0.875rem;
  }

  .post-content :global(img) {
    max-width: 100%;
    height: auto;
    border-radius: 8px;
    margin: 1.5rem 0;
  }

  .post-content :global(strong) {
    font-weight: 600;
    color: #111827;
  }

  .post-content :global(em) {
    font-style: italic;
  }

  .image-gallery {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 16px;
    margin-top: 32px;
  }

  .image-gallery img {
    width: 100%;
    height: auto;
    border-radius: 8px;
    object-fit: cover;
  }

  .post-navigation {
    margin-top: 48px;
    padding-top: 24px;
    border-top: 1px solid #e5e7eb;
  }

  .back-link {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    color: #6b7280;
    text-decoration: none;
    font-size: 0.95rem;
    font-weight: 500;
    transition: color 0.2s ease;
  }

  .back-link:hover {
    color: #C9A857;
  }

  /* Task 11.2: Embedded mindmap styles (compact, fixed height) */
  .post-content :global(.mindmap-embed) {
    background: white;
    border: 1px solid #e5e7eb;
    border-radius: 12px;
    overflow: hidden;
    margin: 1.5rem 0;
    height: 400px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .post-content :global(.mindmap-embed-rendered) {
    display: block;
  }

  .post-content :global(.mindmap-embed-rendered svg) {
    width: 100%;
    height: 400px;
    display: block;
  }

  .post-content :global(.mindmap-embed-fallback) {
    color: #9ca3af;
    font-size: 0.9rem;
    font-style: italic;
    text-align: center;
    padding: 2rem;
  }

  .post-content :global(.mindmap-embed .mindmap-node) {
    cursor: pointer;
    transition: opacity 0.2s ease;
  }

  .post-content :global(.mindmap-embed .mindmap-node:hover rect) {
    filter: brightness(0.95);
  }

  .post-content :global(.mindmap-embed .mindmap-node.highlighted rect) {
    stroke: #C9A857;
    stroke-width: 2.5;
  }

  @media (max-width: 768px) {
    .post-detail {
      padding: 40px 20px;
    }

    .post-title {
      font-size: 1.75rem;
    }

    .post-content {
      font-size: 1rem;
    }

    .post-content :global(.mindmap-embed) {
      height: 300px;
    }
  }
</style>
