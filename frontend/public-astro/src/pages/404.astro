---
/**
 * 404.astro - カスタム404エラーページ
 *
 * Task 2.4: Aboutページと404ページ実装
 * Task 3.1: SEOメタタグ実装
 *
 * Requirements:
 * - 15.1: カスタム404ページ (`404.astro`) を作成
 * - 15.2: 404ページにホームへのナビゲーションを含める
 * - 15.4: 404ページに `<meta name="robots" content="noindex">` を設定
 * - 15.5: 404ページでもサイトヘッダーとナビゲーションを維持
 * - 3.1-3.3, 3.7: SEOメタタグ (OGP, Twitter Card, canonical URL)
 */
import SEO from '../components/SEO.astro';
import { get404PageContent, getSiteMetadata } from '../lib/staticPageUtils';

const notFoundContent = get404PageContent();
const siteMetadata = getSiteMetadata();
const SITE_URL = import.meta.env.SITE_URL || import.meta.env.SITE || 'https://example.com';
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <!-- SEO Meta Tags (Task 3.1 - with noindex for 404) -->
    <SEO
      title={notFoundContent.title}
      description={notFoundContent.message}
      canonicalUrl={`${SITE_URL}/404`}
      type="website"
      noindex={true}
      siteName={siteMetadata.siteName}
    />

    <!-- Global Styles -->
    <style>
      @import '../styles/global.css';
    </style>
  </head>
  <body class="min-h-screen bg-gray-50">
    <!-- Requirement 15.5: Site header and navigation maintained -->
    <header class="site-header">
      <a href="/" class="site-logo">{siteMetadata.siteName}</a>
      <nav class="header-nav">
        <a href="/" class="nav-link">ホーム</a>
        <a href="/about" class="nav-link">About</a>
      </nav>
    </header>

    <!-- 404 Content -->
    <main class="error-container">
      <div class="error-content">
        <!-- Error Icon -->
        <div class="error-icon">
          <svg xmlns="http://www.w3.org/2000/svg" width="80" height="80" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="10"></circle>
            <path d="M16 16s-1.5-2-4-2-4 2-4 2"></path>
            <line x1="9" y1="9" x2="9.01" y2="9"></line>
            <line x1="15" y1="9" x2="15.01" y2="9"></line>
          </svg>
        </div>

        <!-- Error Code -->
        <h1 class="error-code">404</h1>

        <!-- Error Title -->
        <h2 class="error-title">ページが見つかりません</h2>

        <!-- Error Message -->
        <p class="error-message">{notFoundContent.message}</p>

        <!-- Requirement 15.2: Home navigation -->
        <a href={notFoundContent.homeLink} class="home-button">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path>
            <polyline points="9 22 9 12 15 12 15 22"></polyline>
          </svg>
          {notFoundContent.homeButtonText}
        </a>

        <!-- Suggestions -->
        <div class="suggestions">
          <p class="suggestions-title">こちらもお試しください:</p>
          <ul class="suggestions-list">
            {notFoundContent.suggestions.map((suggestion) => (
              <li>
                <a href={suggestion.link} class="suggestion-link">{suggestion.text}</a>
              </li>
            ))}
          </ul>
        </div>
      </div>
    </main>
  </body>
</html>

<style>
  /* Header Styles - Consistent with site */
  .site-header {
    background: white;
    border-bottom: 1px solid #e5e7eb;
    padding: 16px 32px;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .site-logo {
    font-size: 1.25rem;
    font-weight: 600;
    color: #2D2A5A;
    text-decoration: none;
    font-family: 'Caveat', cursive;
  }

  .site-logo:hover {
    color: #C9A857;
  }

  .header-nav {
    display: flex;
    gap: 24px;
  }

  .nav-link {
    color: #6b7280;
    text-decoration: none;
    font-size: 0.95rem;
    font-weight: 500;
    transition: color 0.2s ease;
  }

  .nav-link:hover {
    color: #C9A857;
  }

  /* Error Container */
  .error-container {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    min-height: calc(100vh - 80px);
    padding: 40px 20px;
    text-align: center;
  }

  .error-content {
    max-width: 500px;
  }

  .error-icon {
    color: #9ca3af;
    margin-bottom: 24px;
  }

  .error-code {
    font-size: 6rem;
    font-weight: 700;
    color: #2D2A5A;
    margin: 0;
    line-height: 1;
  }

  .error-title {
    font-size: 1.5rem;
    font-weight: 600;
    color: #374151;
    margin: 16px 0;
  }

  .error-message {
    font-size: 1rem;
    color: #6b7280;
    margin: 0 0 32px 0;
    line-height: 1.6;
  }

  .home-button {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: #2D2A5A;
    color: white;
    padding: 12px 24px;
    border-radius: 8px;
    text-decoration: none;
    font-weight: 500;
    font-size: 1rem;
    transition: all 0.2s ease;
  }

  .home-button:hover {
    background: #C9A857;
    transform: translateY(-2px);
  }

  .suggestions {
    margin-top: 48px;
    padding-top: 32px;
    border-top: 1px solid #e5e7eb;
  }

  .suggestions-title {
    font-size: 0.875rem;
    color: #9ca3af;
    margin: 0 0 16px 0;
  }

  .suggestions-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .suggestion-link {
    color: #6b7280;
    text-decoration: none;
    font-size: 0.95rem;
    transition: color 0.2s ease;
  }

  .suggestion-link:hover {
    color: #C9A857;
    text-decoration: underline;
  }

  @media (max-width: 768px) {
    .site-header {
      padding: 12px 20px;
    }

    .header-nav {
      gap: 16px;
    }

    .error-code {
      font-size: 4rem;
    }

    .error-title {
      font-size: 1.25rem;
    }
  }
</style>
