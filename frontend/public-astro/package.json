{
  "name": "serverless-blog-public-astro",
  "type": "module",
  "version": "1.0.0",
  "description": "Serverless Blog Public Site - Astro SSG",
  "scripts": {
    "dev": "astro dev",
    "start": "astro dev",
    "build": "astro check && astro build",
    "preview": "astro preview",
    "astro": "astro",
    "check": "astro check",
    "test": "vitest",
    "test:coverage": "vitest --coverage",
    "test:integration": "vitest --config vitest.integration.config.ts",
    "validate:build": "bun run scripts/validate-build.ts",
    "validate:build:verbose": "bun run scripts/validate-build.ts --verbose",
    "lighthouse": "lhci autorun",
    "lighthouse:collect": "lhci collect --staticDistDir=./dist",
    "perf": "bun run build && bun run validate:build"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.9",
    "@astrojs/rss": "^4.0.18",
    "@astrojs/sitemap": "^3.7.2",
    "astro": "^6.2.0",
    "d3-hierarchy": "^3.1.2",
    "d3-selection": "^3.0.0",
    "d3-zoom": "^3.0.0"
  },
  "overrides": {
    "vite": "^6.4.2",
    "rollup": "^4.59.0",
    "picomatch": "^4.0.4",
    "lodash": "^4.18.0"
  },
  "devDependencies": {
    "@lhci/cli": "^0.15.1",
    "@tailwindcss/vite": "^4.2.4",
    "@types/bun": "^1.3.13",
    "@types/d3-hierarchy": "^3.1.7",
    "@types/d3-selection": "^3.0.11",
    "@types/d3-zoom": "^3.0.8",
    "@types/js-yaml": "^4.0.9",
    "@vitest/coverage-v8": "^4.1.5",
    "js-yaml": "^4.1.1",
    "jsdom": "^29.1.1",
    "tailwindcss": "^4.2.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  }
}
