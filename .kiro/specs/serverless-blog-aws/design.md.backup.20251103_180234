import { faker } from '@faker-js/faker';

interface BlogPostTestData {
  id?: string;
  title?: string;
  content?: string;
  category?: string;
  tags?: string[];
  publishStatus?: 'draft' | 'published';
  authorId?: string;
  createdAt?: string;
  updatedAt?: string;
  publishedAt?: string;
  imageUrls?: string[];
}

export const createBlogPostTestData = (overrides: BlogPostTestData = {}): BlogPostItem => {
  const createdAt = overrides.createdAt || faker.date.past().toISOString();
  const updatedAt = overrides.updatedAt || faker.date.recent().toISOString();
  const publishStatus = overrides.publishStatus || 'draft';

  return {
    id: overrides.id || faker.string.uuid(),
    title: overrides.title || faker.lorem.sentence(),
    content: overrides.content || faker.lorem.paragraphs(3),
    category: overrides.category || faker.helpers.arrayElement(['tech', 'life', 'travel']),
    tags: overrides.tags || faker.helpers.arrayElements(['typescript', 'aws', 'serverless'], 2),
    publishStatus,
    authorId: overrides.authorId || faker.string.uuid(),
    createdAt,
    updatedAt,
    publishedAt: publishStatus === 'published' ? (overrides.publishedAt || updatedAt) : undefined,
    imageUrls: overrides.imageUrls || [],
  };
};

// 使用例
